+	const timestamp = new Date().toISOString().replace(/[:.]/g, '-')
+
+	return new File([file], `${CLIPBOARD_IMAGE_PREFIX}-${timestamp}.${extension}`, {
+		type: normalizedType,
+		lastModified: Date.now()
+	})
+}
