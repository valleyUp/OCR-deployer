# -----------------------------------------------------------------------------
# Image tags (compose runtime only; build happens via scripts/build-images.sh)
# -----------------------------------------------------------------------------
VLLM_IMAGE=glm-ocr-vllm:nightly
PIPELINE_IMAGE=glm-ocr-pipeline:local
BACKEND_IMAGE=glm-ocr-backend:local
FRONTEND_IMAGE=glm-ocr-frontend:local
PYPI_INDEX_URL=https://mirrors.tuna.tsinghua.edu.cn/pypi/web/simple
NPM_REGISTRY_URL=https://registry.npmmirror.com

# Optional custom container names
VLLM_CONTAINER_NAME=glm-ocr-vllm
PIPELINE_CONTAINER_NAME=glm-ocr-pipeline
BACKEND_CONTAINER_NAME=glm-ocr-backend
FRONTEND_CONTAINER_NAME=glm-ocr-frontend

# -----------------------------------------------------------------------------
# Shared HuggingFace cache path (host path, relative to deploy/docker-compose.yml)
# -----------------------------------------------------------------------------
HF_CACHE_DIR=../runtime/huggingface
HF_TOKEN=
# 离线模式：内网/无网络环境设为 1，强制从本地缓存加载模型
HF_HUB_OFFLINE=0
TRANSFORMERS_OFFLINE=0

# vLLM settings
MODEL_NAME=zai-org/GLM-OCR
SERVED_MODEL_NAME=glm-ocr
# GLM-OCR/vLLM 仅支持 GPU 推理；不要设置 CPU device。
# - VLLM_GPU_DEVICES=0 或 0,1 控制可见物理 GPU
# - 多 GPU 时 VLLM_TENSOR_PARALLEL_SIZE 应与 VLLM_GPU_DEVICES 数量一致
VLLM_GPU_DEVICES=0
VLLM_TENSOR_PARALLEL_SIZE=1
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_NUM_SPECULATIVE_TOKENS=3
VLLM_HOST_PORT=8080

# pipeline settings
PIPELINE_HOST_PORT=5002
# layout 模型设备控制：
# - LAYOUT_DEVICE=cpu 强制 layout 模型跑 CPU
# - LAYOUT_DEVICE=cuda:0 使用容器内第 0 张可见 GPU
# - LAYOUT_GPU_DEVICES 控制 pipeline 容器可见的物理 GPU；例如 0 或 1
#   若 LAYOUT_GPU_DEVICES=1，则容器内应使用 LAYOUT_DEVICE=cuda:0
# - layout 跑 CPU 时可设 LAYOUT_DEVICE=cpu，并将 LAYOUT_GPU_DEVICES=none
LAYOUT_DEVICE=cuda:0
LAYOUT_GPU_DEVICES=0
PIPELINE_SERVER_MODE=gunicorn
PIPELINE_SERVER_PORT=5002
PIPELINE_GUNICORN_WORKERS=1
PIPELINE_GUNICORN_THREADS=8
PIPELINE_GUNICORN_TIMEOUT=300
PIPELINE_GUNICORN_GRACEFUL_TIMEOUT=60
PIPELINE_GUNICORN_KEEPALIVE=10
GLMOCR_CONFIG_PATH=/etc/glm-ocr/server.config.yaml
GLMOCR_LOG_LEVEL=INFO
GLMOCR_MODE=selfhosted
GLMOCR_OCR_API_HOST=vllm
GLMOCR_OCR_API_PORT=8000
GLMOCR_OCR_MODEL=glm-ocr

# backend settings
BACKEND_HOST_PORT=8000
BACKEND_DATA_DIR=../runtime/backend-data
LAYOUT_OCR_URL=http://pipeline:5002/glmocr/parse
DATABASE_URL=sqlite+aiosqlite:///./data/tasks.db
BACKEND_LOG_LEVEL=INFO
BACKEND_DEBUG=false
FORMULA_RENDERER_SCRIPT=/opt/formula-renderer/render-formula.cjs
FORMULA_RENDER_TIMEOUT=20
# 任务级并发：同一后端进程内可以同时运行的任务数
WORKER_COUNT=5
MAX_CONCURRENT_TASKS=5
# 单任务内多页 layout+OCR 的并行度；1 = 顺序（默认，与老行为一致），>1 启用并发
LAYOUT_PAGE_PARALLELISM=1
# 前端单文件上传上限（MB），通过 GET /api/v1/config 暴露给 UI
MAX_UPLOAD_MB=100

# frontend settings
FRONTEND_HOST_PORT=3000
